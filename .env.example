# MongoDB Connection String
# Get your connection string from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databaseName?retryWrites=true&w=majority

# Session Secret for Express Session
# Generate a random secret string for production
SESSION_SECRET=your_random_secret_key_here

# ImgBB API Key for Image Upload
# Sign up at https://imgbb.com/ to get your API key
IMGBB_API_KEY=your_imgbb_api_key_here

# Node Environment (development or production)
NODE_ENV=development

# Port the server listens on (defaults to 4000)
PORT=4000

# Allowed CORS origin — the URL the frontend is served from
CLIENT_URL=http://localhost:5173

# Optional: public URL for the keep-alive self-ping (free-tier hosts that sleep).
# Leave unset to disable. Example: https://your-app.onrender.com
SELF_PING_URL=


# Gmail Credentials for Sending Emails
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_app_password

# Stripe secret key (optional). When unset, plan changes apply immediately in
# "mock" mode for development. When set, paid upgrades will go through Stripe Checkout.
STRIPE_SECRET_KEY=

# Public base URL of the deployed app (used to build the calendar .ics feed URL).
# In production this is your app's origin; leave unset in dev to default to
# http://localhost:<PORT>.
APP_URL=

# AI insights (Premium feature). Uses an OpenAI-compatible Chat Completions API.
# Configured for Groq by default; set AI_API_KEY to enable the feature. When
# unset, the AI insights card shows a "not configured" message.
#   AI_BASE_URL — OpenAI-compatible base URL (default: https://api.groq.com/openai/v1)
#   AI_MODEL    — model id (default: llama-3.3-70b-versatile)
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Google Calendar sync (Premium feature). Create an OAuth 2.0 Client (type: Web
# application) in Google Cloud Console, enable the Google Calendar API, and add
# the redirect URI below to the client's "Authorized redirect URIs".
#   Redirect URI = <APP_URL>/auth/google/calendar/callback
#                  (e.g. http://localhost:4000/auth/google/calendar/callback in dev)
# Requested scopes: openid, email, calendar.events. When unset, the Google
# Calendar option is hidden and sync is disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to <APP_URL>/auth/google/calendar/callback
GOOGLE_REDIRECT_URI=

# Log verbosity: debug | info | warn | error.
# Defaults to "debug" in development and "info" in production.
LOG_LEVEL=

# Error tracking (optional). When unset, exceptions are written to logs only.
# When set, wire a provider (e.g. Sentry) in server/services/errorTracking.js.
SENTRY_DSN=